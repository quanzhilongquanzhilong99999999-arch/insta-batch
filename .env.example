# Copy to .env (gitignored) and fill real values.

# Token for the proxy provider API referenced in config/settings.yaml
PROXY_API_TOKEN=your-proxy-api-token-here

# API Keys for the HTTP service — comma-separated list, each caller gets their own.
# Generate random ones, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
API_KEYS=change-me-key-1,change-me-key-2

# API server bind address (scripts/run_api.py honors these)
API_HOST=0.0.0.0
API_PORT=8000

# Optional: override log level for a one-off run
# LOG_LEVEL=DEBUG
